{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm build --filter @flowtiq/admin-portal",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/.well-known/:path*",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
