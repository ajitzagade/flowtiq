NODE_ENV=production
PORT=3001

# Database (Railway PostgreSQL or Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-min-64-chars
JWT_REFRESH_SECRET=change-this-to-another-long-random-string-min-64-chars

# CORS — your Vercel frontend URL
CORS_ORIGIN=https://your-app.vercel.app

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Admin Portal URL
ADMIN_PORTAL_URL=https://your-app.vercel.app
